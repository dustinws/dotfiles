snippet cla
	class ${1:ClassName} {
	  ${2}
	}

snippet met
	${1:method}(${2:param}) {
	  ${2:// stuff}
	}

snippet fun
	function ${1}(${2}) {
	  ${3}
	}

snippet iaf
	(${1}) => ${2}

snippet afun
	(${1}) => {
	  ${2}
	}

snippet con
	const ${1:variable} = ${2:value};

snippet desc
	describe('${1}', () => {
	  ${2}
	});

snippet it
	it('${1}', () => {
	  ${2}
	});

snippet ait
	it('${1}', async () => {
	  ${2}
	});
