{
  // ---------------------------------------------------------------------------
  // Display Settings
  // ---------------------------------------------------------------------------
  "workbench.colorTheme": "Palenight Theme",
  "editor.lineHeight": 30,
  "editor.fontFamily": "'Operator Mono', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 22,
  "editor.fontWeight": "200",
  "editor.rulers": [
    80
  ],
  "terminal.integrated.fontSize": 18,
  "editor.lineNumbers": "relative",
  "workbench.fontAliasing": "auto",
  // ---------------------------------------------------------------------------
  // Tabs
  // ---------------------------------------------------------------------------
  "editor.tabSize": 2,
  // ---------------------------------------------------------------------------
  // Minimalist Settings
  // ---------------------------------------------------------------------------
  "editor.folding": false,
  "editor.minimap.enabled": false,
  "workbench.activityBar.visible": false,
  "workbench.editor.showTabs": false,
  "workbench.editor.labelFormat": "medium",
  "editor.renderIndentGuides": false,
  "editor.autoSurround": "languageDefined",
  "editor.renderLineHighlight": "gutter",
  // ---------------------------------------------------------------------------
  // Editor Behavior
  // ---------------------------------------------------------------------------
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "editor.renderWhitespace": "none",
  "editor.matchBrackets": "never",
  // ---------------------------------------------------------------------------
  // Language Settings
  // ---------------------------------------------------------------------------
  "typescript.preferences.quoteStyle": "single",
  // ---------------------------------------------------------------------------
  // Plugin Settings
  // ---------------------------------------------------------------------------
  "liveshare.authenticationProvider": "GitHub",
  // ---------------------------------------------------------------------------
  // Vim Settings
  // ---------------------------------------------------------------------------
  // Change the leader key
  "vim.leader": ",",
  // Key Bindings for insert mode
  "vim.insertModeKeyBindings": [
    // Allow double tapping "jj" to go back to normal mode
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  // Key bindings for normal mode
  "vim.normalModeKeyBindingsNonRecursive": [
    // Allow the "new line below current" command to stay in normal mode
    {
      "before": [
        "o"
      ],
      "after": [
        "o",
        "<Esc>"
      ]
    },
    // Allow the "new line above current" command to stay in normal mode
    {
      "before": [
        "O"
      ],
      "after": [
        "O",
        "<Esc>"
      ]
    },
    {
      "before": [
        "<leader>", "w"
      ],
      "commands": [
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>", "q"
      ],
      "commands": [
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "before": [
        "<leader>", "w", "q"
      ],
      "commands": [
        "workbench.action.files.save",
        "workbench.action.closeActiveEditor"
      ]
    }
  ]
}
